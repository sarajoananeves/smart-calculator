{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TestCompass Result",
  "description": "A single TestCompass test run result",
  "type": "object",
  "required": ["test_id", "test_title", "test_def_hash", "run", "environment", "outcome", "steps"],
  "additionalProperties": false,
  "properties": {
    "test_id": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]+$",
      "description": "Stable test ID, format: PROJECT-NUMBER (e.g., CALC-702)"
    },
    "test_title": {
      "type": "string",
      "description": "Test title at run time (denormalized; survives later renames)"
    },
    "test_def_hash": {
      "type": "string",
      "description": "Hash of the test's steps at run time"
    },
    "run": {
      "type": "object",
      "required": ["started_at", "finished_at", "duration_seconds", "user", "git_commit"],
      "additionalProperties": false,
      "properties": {
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" },
        "duration_seconds": { "type": "integer", "minimum": 0 },
        "user": { "type": "string", "description": "From git config user.email" },
        "git_commit": { "type": "string", "description": "Short SHA of HEAD at run time" }
      }
    },
    "environment": {
      "type": "object",
      "required": ["browser", "os"],
      "additionalProperties": false,
      "properties": {
        "browser": { "type": "string" },
        "os": { "type": "string" }
      }
    },
    "outcome": {
      "type": "object",
      "required": ["overall", "notes"],
      "additionalProperties": false,
      "properties": {
        "overall": { "type": "string", "enum": ["pass", "fail"] },
        "failed_at_step": { "type": "integer", "minimum": 1 },
        "notes": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "overall": { "const": "fail" } }, "required": ["overall"] },
          "then": { "required": ["failed_at_step"] }
        }
      ]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["n", "status"],
        "additionalProperties": false,
        "properties": {
          "n": { "type": "integer", "minimum": 1 },
          "status": { "type": "string", "enum": ["pass", "fail"] },
          "description": { "type": "string", "description": "Required when status is fail" },
          "patterns_offered": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "status": { "const": "fail" } }, "required": ["status"] },
            "then": { "required": ["description"] }
          }
        ]
      }
    }
  }
}